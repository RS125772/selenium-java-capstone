<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite">

    <!-- 🔥 Add listeners here -->
    <listeners>
        <listener class-name="com.automation.listeners.ExtentListener"/>
    </listeners>

    <test name="UI Tests" parallel="tests" thread-count="3">
        <classes>
            <class name="com.automation.tests.LoginTest"/>
            <class name="com.automation.tests.RegistrationTest"/>
            <class name="com.automation.tests.HomePageTest"/>
        </classes>
    </test>

</suite>